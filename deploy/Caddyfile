# TermRouter public reverse proxy (Caddy)
#
# Replace ai.example.com with the real domain. TermRouter itself binds to
# 127.0.0.1:8787 (loopback only); Caddy is the only public listener.
#
# Do NOT proxy /admin/v1/* or the Web Console (127.0.0.1:8788). Only the
# inference paths below are reachable from the internet.
#
# To optionally expose health/readiness endpoints, uncomment:
#   @health path /health /ready
#   handle @health {
#       reverse_proxy 127.0.0.1:8787
#   }

ai.example.com {
    encode zstd gzip

    @inference path /v1/models /v1/chat/completions /v1/messages
    handle @inference {
        reverse_proxy 127.0.0.1:8787
    }

    handle {
        respond "Not Found" 404
    }

    header {
        -Server
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        Strict-Transport-Security "max-age=31536000"
        Cache-Control "no-store"
    }

    log {
        output file /var/log/caddy/termrouter-access.log {
            roll_size 10MiB
            roll_keep 5
            roll_keep_for 168h
        }
        # JSON access log by default includes request.headers (Authorization
        # bearer token). Strip request headers so secrets are never logged.
        # Response/request bodies are never logged by Caddy.
        format filter {
            wrap json
            fields {
                request.headers delete
            }
        }
    }
}
